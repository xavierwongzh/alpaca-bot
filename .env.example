# Copy this file to ".env" and fill in your keys.
# NEVER put real keys in this file — it is a template meant to be committed.

# --- Alpaca PAPER trading keys ---
# Generate these from the Alpaca dashboard with the account switched to "Paper".
# This bot refuses to run with anything that looks like a live key.
ALPACA_API_KEY=PKXXXXXXXXXXXXXXXXXX
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# Alpaca paper endpoint. Do NOT change this to a live endpoint.
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# --- OpenAI ---
OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXX

# --- Options-flow data (optional) ---
# Tradier is the PRIMARY flow provider. If this token is absent the scanner falls
# back to the free yfinance feed automatically, so it is optional. When set, also
# add it to the GitHub Actions repository secrets. Uses the Tradier sandbox by
# default (see FlowConfig.tradier_base_url to switch to production/real-time).
TRADIER_ACCESS_TOKEN=
